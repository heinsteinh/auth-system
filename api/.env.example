NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://auth_user:auth_password@localhost:5432/auth_db?schema=public"

# Generate with: openssl rand -base64 48 | tr -d '\n/+=' | cut -c1-48
JWT_ACCESS_SECRET="replace-with-a-32-plus-char-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-32-plus-char-random-string"

ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7

APP_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:5173"

SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Auth System <no-reply@example.com>"

# Seeded admin (used by `pnpm seed`) — leave unset to skip seeding
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMeStrong123!"
ADMIN_NAME="Admin"
